<Window x:Class="CountryDetails.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CountryDetails"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Titre -->
            <RowDefinition Height="Auto"/>
            <!-- Barre de recherche -->
            <RowDefinition Height="Auto"/>
            <!-- Séparateur -->
            <RowDefinition Height="*"/>
            <!-- Contenu principal -->
            <RowDefinition Height="Auto"/>
            <!-- Message d'erreur -->
        </Grid.RowDefinitions>

        <!-- ===== TITRE ===== -->
        <TextBlock Grid.Row="0"
                   Text="Recherche d'informations sur un pays"
                   FontSize="18"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"/>

        <!-- ===== BARRE DE RECHERCHE ===== -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,10">

            <TextBlock Text="Nom du pays :"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <TextBox x:Name="TxtNomPays"
                     Width="220"
                     Height="30"
                     VerticalContentAlignment="Center"
                     Padding="5,0"
                     FontSize="13"/>

            <Button x:Name="BtnCharger"
                    Content="Charger"
                    Width="90"
                    Height="30"
                    Margin="10,0,0,0"
                    FontSize="13"
                    Click="BtnCharger_Click"
                    />
        </StackPanel>

        <!-- ===== SÉPARATEUR ===== -->
        <Separator Grid.Row="2" Margin="0,0,0,10"/>

        <!-- ===== CONTENU PRINCIPAL ===== -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <!-- Infos texte -->
                <ColumnDefinition Width="20"/>
                <!-- Espace -->
                <ColumnDefinition Width="220"/>
                <!-- Drapeau -->
            </Grid.ColumnDefinitions>

            <!-- ─── COLONNE GAUCHE : champs d'information ─── -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <!-- Étiquette -->
                    <ColumnDefinition Width="*"/>
                    <!-- Valeur -->
                </Grid.ColumnDefinitions>

                <!-- Nom commun -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Nom commun :"
                           VerticalAlignment="Center"
                           Margin="0,0,8,8"/>
                <TextBox x:Name="TxtNomCommun"
                         Grid.Row="0" Grid.Column="1"
                         Height="28"
                         IsReadOnly="True"
                         VerticalContentAlignment="Center"
                         Padding="5,0"
                         Margin="0,0,0,8"/>

                <!-- Nom officiel -->
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="Nom officiel :"
                           VerticalAlignment="Center"
                           Margin="0,0,8,8"/>
                <TextBox x:Name="TxtNomOfficiel"
                         Grid.Row="1" Grid.Column="1"
                         Height="28"
                         IsReadOnly="True"
                         VerticalContentAlignment="Center"
                         Padding="5,0"
                         Margin="0,0,0,8"/>

                <!-- Capitale(s) -->
                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="Capitale(s) :"
                           VerticalAlignment="Center"
                           Margin="0,0,8,8"/>
                <TextBox x:Name="TxtCapitales"
                         Grid.Row="2" Grid.Column="1"
                         Height="28"
                         IsReadOnly="True"
                         VerticalContentAlignment="Center"
                         Padding="5,0"
                         Margin="0,0,0,8"/>

                <!-- Région -->
                <TextBlock Grid.Row="3" Grid.Column="0"
                           Text="Région :"
                           VerticalAlignment="Center"
                           Margin="0,0,8,8"/>
                <TextBox x:Name="TxtRegion"
                         Grid.Row="3" Grid.Column="1"
                         Height="28"
                         IsReadOnly="True"
                         VerticalContentAlignment="Center"
                         Padding="5,0"
                         Margin="0,0,0,8"/>

                <!-- Sous-région -->
                <TextBlock Grid.Row="4" Grid.Column="0"
                           Text="Sous-région :"
                           VerticalAlignment="Center"
                           Margin="0,0,8,8"/>
                <TextBox x:Name="TxtSousRegion"
                         Grid.Row="4" Grid.Column="1"
                         Height="28"
                         IsReadOnly="True"
                         VerticalContentAlignment="Center"
                         Padding="5,0"
                         Margin="0,0,0,8"/>

                <!-- Population -->
                <TextBlock Grid.Row="5" Grid.Column="0"
                           Text="Population :"
                           VerticalAlignment="Center"
                           Margin="0,0,8,8"/>
                <TextBox x:Name="TxtPopulation"
                         Grid.Row="5" Grid.Column="1"
                         Height="28"
                         IsReadOnly="True"
                         VerticalContentAlignment="Center"
                         Padding="5,0"
                         Margin="0,0,0,8"/>

                <!-- Superficie -->
                <TextBlock Grid.Row="6" Grid.Column="0"
                           Text="Superficie :"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <TextBox x:Name="TxtSuperficie"
                         Grid.Row="6" Grid.Column="1"
                         Height="28"
                         IsReadOnly="True"
                         VerticalContentAlignment="Center"
                         Padding="5,0"/>
            </Grid>

            <!-- ─── COLONNE DROITE : drapeau ─── -->
            <StackPanel Grid.Column="2"
                        HorizontalAlignment="Center" Margin="0,0,0,302">

                <TextBlock Text="Drapeau :"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>

                <Border BorderBrush="LightGray"
                        BorderThickness="1"
                        Width="200"
                        Height="130">
                    <Image x:Name="ImgDrapeau"
                           Stretch="Uniform"/>
                </Border>
            </StackPanel>
        </Grid>

        <!-- ===== MESSAGE D'ERREUR ===== -->
        <TextBlock x:Name="TxtErreur"
                   Text="Afficher les erreurs ici...
                   Sinon avec des MessageBox() ..."
                   Grid.Row="4"
                   Foreground="Red"
                   TextWrapping="Wrap"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,0"/>

    </Grid>
</Window>
